# Copy this file to .env and fill in your values before running docker-compose.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Single instance hosts three databases: fleet_vehicles, fleet_drivers, fleet_usage
DB_USER=postgres
DB_PASSWORD=postgres

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# ── Redis ─────────────────────────────────────────────────────────────────────
# Used by API Gateway for request rate limiting
REDIS_HOST=redis
REDIS_PORT=6379

# ── Eureka Service Registry ───────────────────────────────────────────────────
EUREKA_SERVER_URL=http://service-registry:8761/eureka/
